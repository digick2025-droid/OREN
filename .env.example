# Supabase — copier dans .env.local et remplir avec les valeurs du projet
# (Dashboard Supabase > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clé service role — UNIQUEMENT côté serveur, jamais exposée au client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Fournisseur de paiement : "simulated" (règle tout de suite, pour le dev)
# ou "camerpay" (Mobile Money réel, confirmé par webhook signé).
PAYMENT_PROVIDER=simulated

# ------------------------------------------------------------------
# CamerPay — requis uniquement si PAYMENT_PROVIDER=camerpay
# (Tableau de bord CamerPay > Clés API & Webhooks)
# ------------------------------------------------------------------

# Endpoint d'initiation (POST JSON) et token d'accès.
# Confirmé dans la doc « API REST » du tableau de bord CamerPay.
CAMERPAY_API_URL=https://camerpay.biz/api/payment/initiate
CAMERPAY_API_KEY=

# Secret HMAC-SHA256 servant à vérifier la signature des webhooks.
# Sans lui, /api/payments/webhook refuse TOUT : aucun mode dégradé.
CAMERPAY_WEBHOOK_SECRET=

# URL publique du webhook, transmise à CamerPay comme `merchant_callback_url`.
# À déclarer à l'identique dans le tableau de bord CamerPay.
CAMERPAY_CALLBACK_URL=https://votre-domaine/api/payments/webhook

# Page sur laquelle CamerPay renvoie le client après le paiement
# (`merchant_return_url`). Le parcours CamerPay est une REDIRECTION :
# le client quitte l'appli, paie sur camerpay.biz, puis revient ici.
CAMERPAY_RETURN_URL=https://votre-domaine/paiement/retour
